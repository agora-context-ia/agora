# Public endpoint
NGINX_SERVER_NAME=agora.example.com
HTTP_PORT=80
FRONTEND_URL=https://agora.example.com
CORS_ORIGIN=https://agora.example.com
COOKIE_SECURE=true

# PostgreSQL and Redis (replace all CHANGE_ME values)
POSTGRES_USER=contexthub
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DATABASE_PASSWORD
POSTGRES_DB=contexthub
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD

# AI and storage
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIM=768
OLLAMA_CHAT_MODELS=llama3.2:1b
CREDENTIALS_ENCRYPTION_KEY=CHANGE_ME_64_HEX_CHARACTERS

# Optional server-wide provider fallbacks. Prefer per-organization keys in the UI.
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
