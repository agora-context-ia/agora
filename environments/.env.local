# Root environment: consumed by docker-compose.yml (infra:up / infra:down)
# to run Postgres, Redis and Ollama locally. See AGENTS.md.

POSTGRES_USER=contexthub
POSTGRES_PASSWORD=contexthub_local_pw
POSTGRES_DB=contexthub
POSTGRES_PORT=5432

REDIS_PASSWORD=contexthub_redis_pw
REDIS_PORT=6379

OLLAMA_PORT=11434
# Modelo de embeddings que el sidecar `ollama-init` descarga al levantar la
# infra. Debe coincidir con EMBEDDING_MODEL del backend.
EMBEDDING_MODEL=nomic-embed-text
